---
const { title, date, category } = Astro.props;
---
<div class="group p-6 bg-white rounded-2xl shadow-sm border border-slate-100 hover:border-indigo-300 transition-all hover:-translate-y-1">
  <span class="text-xs font-bold text-indigo-500 uppercase tracking-wider">{category}</span>
  <h3 class="text-xl font-bold mt-2 group-hover:text-indigo-600">{title}</h3>
  <p class="text-slate-500 mt-1 text-sm">{date}</p>
  <div class="mt-4 pt-4 border-t border-slate-50 flex justify-end">
    <button class="text-indigo-600 font-semibold text-sm">상세보기 &rarr;</button>
  </div>
</div>